    // ── Root Bundle ──────────────────────────────────────────────────
    // The top-level entry point that wires together all behaviors,
    // agents, modules, and external dependencies.
    root_foundation [label="Foundation v2.0.0\n4 tools · 11 agents\n~11537 tok aggregate", shape=box, fillcolor="#80cbc4", style="filled,rounded,bold", penwidth=2]

    // ── Behaviors — Composable Capabilities ──────────────────────────
    // Each behavior adds a distinct capability (tools, context, agents)
    // to the foundation bundle. Behaviors are mixed in at load time.
