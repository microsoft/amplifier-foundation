// Session Management — auto-naming, event logging, and a dedicated session analysis agent
digraph behavior_sessions {
    rankdir=LR
    fontname="Helvetica"
    fontsize=12
    label="Session Management Behavior\nAuto-naming, event logging, and a dedicated session analysis agent"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="bbce379d4b4692210336372c4824c1f0641d7d373e40ec33a0e0a767bfc8c2d9"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    root [label="Session Management\nNaming, logging, and analysis\n~140 tok", shape=box, fillcolor="#c8e6c9", style="filled,rounded,bold", color="#80cbc4"]
    hook_hooks_session_naming [label="Auto Session Naming\nNames sessions after 2 turns\n~43 tok", shape=box, fillcolor="#ffe0b2", style="filled,rounded"]
    agent_foundation_session_analyst [label="Session Analyst\nDebug, repair, and search sessions\n~887 tok", shape=box, fillcolor="#fff9c4", style="filled,rounded"]
    summary [label="Total: ~1204 tok\nagents: 887, hooks: 43, includes: 134", shape=box, fillcolor="#c8e6c9", style="filled,rounded", peripheries=2]

    root -> hook_hooks_session_naming
    root -> agent_foundation_session_analyst
    root -> cluster_inc_0_root [lhead=cluster_inc_0]
    root -> summary [style=dashed, arrowhead=none]

    // Included behavior: Session Logging
    subgraph cluster_inc_0 {
        label="Session Logging\nJSONL event recording"
        style="filled,rounded"
        fillcolor="#f9f9f9"
        color="#999999"

        cluster_inc_0_root [label="Session Logging\nJSONL event recording\n~85 tok", shape=box, fillcolor="#c8e6c9", style="filled,rounded"]
        cluster_inc_0_hook_hooks_logging [label="Logging Hook\nWrites events to session log\n~49 tok", shape=box, fillcolor="#ffe0b2", style="filled,rounded"]
        cluster_inc_0_root -> cluster_inc_0_hook_hooks_logging
    }

    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_root [label="Bundle Root", shape=box, fillcolor="#80cbc4", style="filled,rounded"]
        leg_agent [label="Agent", shape=box, fillcolor="#c8e6c9", style="filled,rounded"]
        leg_hook [label="Hook", shape=box, fillcolor="#ffe0b2", style="filled,rounded"]
        leg_local [label="Local Include", shape=box, fillcolor="#e0f2f1", style="filled,rounded"]
        leg_root -> leg_agent -> leg_hook -> leg_local [style=invis]
    }
}