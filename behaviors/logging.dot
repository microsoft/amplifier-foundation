// Session Logging — records session events to JSONL files for analysis and debugging
digraph behavior_logging {
    rankdir=LR
    fontname="Helvetica"
    fontsize=12
    label="Session Logging Behavior\nRecords session events to JSONL files for analysis and debugging"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="9d5880d9082c2cf100937d2e89dc44be02af28ec2f37e1986bc339985a7cf3e6"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    root [label="Session Logging\nJSONL event recording\n~85 tok", shape=box, fillcolor="#c8e6c9", style="filled,rounded", color="#80cbc4"]
    hook_hooks_logging [label="Logging Hook\nWrites events to session log file\n~49 tok", shape=box, fillcolor="#ffe0b2", style="filled,rounded"]
    summary [label="Total: ~134 tok\nhooks: 49", shape=box, fillcolor="#c8e6c9", style="filled,rounded", peripheries=2]

    root -> hook_hooks_logging
    root -> summary [style=dashed, arrowhead=none]

    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_root [label="Bundle Root", shape=box, fillcolor="#80cbc4", style="filled,rounded"]
        leg_hook [label="Hook", shape=box, fillcolor="#ffe0b2", style="filled,rounded"]
        leg_root -> leg_hook [style=invis]
    }
}