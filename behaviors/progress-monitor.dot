// Progress Monitor — detects when the agent is stuck in analysis loops and nudges it forward
digraph behavior_progress_monitor {
    rankdir=LR
    fontname="Helvetica"
    fontsize=12
    label="Progress Monitor Behavior\nDetects analysis paralysis and nudges the agent to make progress"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="435a04276003b9721f69881550ce73e008e88d2f73ed616cc88eef5798037e08"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    root [label="Progress Monitor\nDetects stuck analysis loops\n~190 tok", shape=box, fillcolor="#c8e6c9", style="filled,rounded", color="#80cbc4"]
    hook_hooks_progress_monitor [label="Progress Hook\nWarns after 30 reads with 0 writes\n~53 tok", shape=box, fillcolor="#ffe0b2", style="filled,rounded"]
    summary [label="Total: ~243 tok\nhooks: 53", shape=box, fillcolor="#c8e6c9", style="filled,rounded", peripheries=2]

    root -> hook_hooks_progress_monitor
    root -> summary [style=dashed, arrowhead=none]

    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_root [label="Bundle Root", shape=box, fillcolor="#80cbc4", style="filled,rounded"]
        leg_hook [label="Hook", shape=box, fillcolor="#ffe0b2", style="filled,rounded"]
        leg_root -> leg_hook [style=invis]
    }
}