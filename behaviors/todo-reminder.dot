// Todo Tracking — task lists with automatic context reminders and visual progress display
digraph behavior_todo_reminder {
    rankdir=LR
    fontname="Helvetica"
    fontsize=12
    label="Todo Tracking Behavior\nTask lists with automatic context reminders and visual progress display"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="563a5b321947de45bbff4960503ab8ef28ff895cb85f17bdb599842091e55634"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    root [label="Todo Tracking\nTask lists with reminders\n~232 tok", shape=box, fillcolor="#c8e6c9", style="filled,rounded", color="#80cbc4"]
    tool_tool_todo [label="Todo Tool\nCreate, update, and track tasks", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
    hook_hooks_todo_reminder [label="Todo Reminder\nInjects pending tasks into context\n~33 tok", shape=box, fillcolor="#ffe0b2", style="filled,rounded"]
    hook_hooks_todo_display [label="Progress Display\nVisual progress bar in terminal\n~41 tok", shape=box, fillcolor="#ffe0b2", style="filled,rounded"]
    summary [label="Total: ~306 tok\nhooks: 74", shape=box, fillcolor="#c8e6c9", style="filled,rounded", peripheries=2]

    root -> tool_tool_todo
    root -> hook_hooks_todo_reminder
    root -> hook_hooks_todo_display
    root -> summary [style=dashed, arrowhead=none]

    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_root [label="Bundle Root", shape=box, fillcolor="#80cbc4", style="filled,rounded"]
        leg_tool [label="Tool", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
        leg_hook [label="Hook", shape=box, fillcolor="#ffe0b2", style="filled,rounded"]
        leg_root -> leg_tool -> leg_hook [style=invis]
    }
}