// File Ops — focused agent for precise file read, write, edit, search, and discovery operations
digraph file_ops {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="File Operations Agent\nPrecise file read, write, edit, search, and discovery"
    labelloc=t
    labeljust=c
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="42076e4bce3954a17db61d5b25a82178eeb6735dbc5cd9bf68ac9ab2fe697f4e"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    agent [label="File Operations\nmodel_role: fast\ndescription: ~371 tok", shape=box, fillcolor="#c8e6c9", style="filled,bold", color="#80cbc4"]
    tool_tool_filesystem [label="File System Access\nRead, write, edit files", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
    tool_tool_search [label="Code Search\nGrep and glob for files", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
    ctx_foundation_context_shared_common_agent_base_md [label="Agent Base Instructions\nShared agent operating rules\n~3543 tok", shape=note, fillcolor="#ffe0b2", style="filled"]
