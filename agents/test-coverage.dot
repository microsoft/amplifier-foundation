// Test Coverage — analyzes test gaps, suggests test cases, and ensures quality through strategic testing
digraph test_coverage {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Test Coverage Agent\nAnalyzes test gaps, suggests cases, and ensures quality through strategic testing"
    labelloc=t
    labeljust=c
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="9799a528cd859cc3e7f064b81d289b06d0665b9946b1249b87eae5b27da068a3"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    agent [label="Test Coverage\nmodel_role: coding, general\ndescription: ~190 tok", shape=box, fillcolor="#c8e6c9", style="filled,bold", color="#80cbc4"]
    tool_tool_filesystem [label="File System Access\nRead test and source files", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
    tool_tool_search [label="Code Search\nFind untested code paths", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
    tool_tool_bash [label="Shell Commands\nRun test suites and coverage", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
    tool_tool_lsp [label="Language Intelligence\nSemantic code analysis (LSP)", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
    ctx_foundation_context_IMPLEMENTATION_PHILOSOPHY_md [label="Implementation Philosophy\nRuthless simplicity principles\n~4382 tok", shape=note, fillcolor="#ffcdd2", style="filled"]
    ctx_foundation_context_MODULAR_DESIGN_PHILOSOPHY_md [label="Modular Design Philosophy\nBricks and studs approach\n~1435 tok", shape=note, fillcolor="#fff9c4", style="filled"]
    ctx_foundation_context_LANGUAGE_PHILOSOPHY_md [label="Language Philosophy\nAI-first language choices\n~3723 tok", shape=note, fillcolor="#ffe0b2", style="filled"]
    ctx_foundation_context_shared_common_agent_base_md [label="Agent Base Instructions\nShared agent operating rules\n~3543 tok", shape=note, fillcolor="#ffe0b2", style="filled"]

    agent -> tool_tool_filesystem
    agent -> tool_tool_search
    agent -> tool_tool_bash
    agent -> tool_tool_lsp
    agent -> ctx_foundation_context_IMPLEMENTATION_PHILOSOPHY_md
    agent -> ctx_foundation_context_MODULAR_DESIGN_PHILOSOPHY_md
    agent -> ctx_foundation_context_LANGUAGE_PHILOSOPHY_md
    agent -> ctx_foundation_context_shared_common_agent_base_md

    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_agent [label="Agent", shape=box, fillcolor="#80cbc4", style="filled,bold"]
        leg_tool [label="Tool", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
        leg_ctx [label="Context File", shape=note, fillcolor="#e1bee7", style="filled,rounded"]
        leg_agent -> leg_tool -> leg_ctx [style=invis]
    }
}