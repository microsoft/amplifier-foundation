// Session Analyst — analyzes, debugs, repairs, and searches Amplifier session transcripts
digraph session_analyst {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Session Analyst Agent\nAnalyzes, debugs, repairs, and searches session transcripts safely"
    labelloc=t
    labeljust=c
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="028726f2b33e990a1dee71709e1c7455d477adc44b66baae7d82549c328fcb2f"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    agent [label="Session Analyst\nmodel_role: fast\ndescription: ~887 tok", shape=box, fillcolor="#fff9c4", style="filled,bold", color="#80cbc4"]
    tool_tool_filesystem [label="File System Access\nRead session log files", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
    tool_tool_search [label="Code Search\nSearch across session data", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
    tool_tool_bash [label="Shell Commands\nParse large JSONL safely", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
    ctx_foundation_context_agents_session_storage_knowledge_md [label="Session Storage Knowledge\nWhere and how sessions are stored\n~2490 tok", shape=note, fillcolor="#ffe0b2", style="filled"]
    ctx_foundation_context_agents_session_repair_knowledge_md [label="Session Repair Knowledge\nFix orphaned calls and violations\n~1222 tok", shape=note, fillcolor="#fff9c4", style="filled"]
    ctx_foundation_context_shared_common_agent_base_md [label="Agent Base Instructions\nShared agent operating rules\n~3543 tok", shape=note, fillcolor="#ffe0b2", style="filled"]

    agent -> tool_tool_filesystem
    agent -> tool_tool_search
    agent -> tool_tool_bash
    agent -> ctx_foundation_context_agents_session_storage_knowledge_md
    agent -> ctx_foundation_context_agents_session_repair_knowledge_md
    agent -> ctx_foundation_context_shared_common_agent_base_md

    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_agent [label="Agent", shape=box, fillcolor="#80cbc4", style="filled,bold"]
        leg_tool [label="Tool", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
        leg_ctx [label="Context File", shape=note, fillcolor="#e1bee7", style="filled,rounded"]
        leg_agent -> leg_tool -> leg_ctx [style=invis]
    }
}