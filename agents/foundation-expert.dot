// Foundation Expert — authoritative advisor for bundle composition, agent authoring, and design patterns
digraph foundation_expert {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Foundation Expert Agent\nAuthoritative advisor for bundle composition, agent authoring, and design patterns"
    labelloc=t
    labeljust=c
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="cf9fd8ff69b5dae28a03eaef746c7b53cb9b0da6e7bf8f4f090c50eeadc24f92"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    agent [label="Foundation Expert\nmodel_role: general\ndescription: ~504 tok", shape=box, fillcolor="#fff9c4", style="filled,bold", color="#80cbc4"]

    // Tools
    tool_tool_filesystem [label="File System Access\nRead docs, examples, patterns", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
    tool_tool_search [label="Code Search\nFind patterns across codebase", shape=box, fillcolor="#bbdefb", style="filled,rounded"]

    // Core documentation (the expert's knowledge base)
    ctx_foundation_docs [label="Documentation Root\nAll foundation docs\n~0 tok", shape=note, fillcolor="#c8e6c9", style="filled"]
    ctx_foundation_docs_BUNDLE_GUIDE_md [label="Bundle Guide\nComplete bundle authoring reference\n~10678 tok", shape=note, fillcolor="#ffcdd2", style="filled"]
    ctx_foundation_docs_AGENT_AUTHORING_md [label="Agent Authoring Guide\nHow to write effective agents\n~2919 tok", shape=note, fillcolor="#ffe0b2", style="filled"]
    ctx_foundation_docs_PATTERNS_md [label="Patterns Catalog\nCommon patterns and examples\n~2692 tok", shape=note, fillcolor="#ffe0b2", style="filled"]
    ctx_foundation_docs_CONCEPTS_md [label="Core Concepts\nFundamental terminology\n~1961 tok", shape=note, fillcolor="#fff9c4", style="filled"]
    ctx_foundation_docs_API_REFERENCE_md [label="API Reference\nProgrammatic interface docs\n~1591 tok", shape=note, fillcolor="#fff9c4", style="filled"]
    ctx_foundation_docs_URI_FORMATS_md [label="URI Formats\nSource URI syntax reference\n~687 tok", shape=note, fillcolor="#c8e6c9", style="filled"]

    // Philosophy context
    ctx_foundation_context [label="Context Root\nPhilosophy documents\n~0 tok", shape=note, fillcolor="#c8e6c9", style="filled"]
    ctx_foundation_context_IMPLEMENTATION_PHILOSOPHY_md [label="Implementation Philosophy\nRuthless simplicity principles\n~4382 tok", shape=note, fillcolor="#ffcdd2", style="filled"]
    ctx_foundation_context_MODULAR_DESIGN_PHILOSOPHY_md [label="Modular Design Philosophy\nBricks and studs approach\n~1435 tok", shape=note, fillcolor="#fff9c4", style="filled"]
    ctx_foundation_context_shared_PROBLEM_SOLVING_PHILOSOPHY_md [label="Problem Solving Philosophy\nAnalysis-first approach\n~652 tok", shape=note, fillcolor="#c8e6c9", style="filled"]
    ctx_foundation_context_ISSUE_HANDLING_md [label="Issue Handling Guide\nBug triage and resolution\n~8517 tok", shape=note, fillcolor="#ffcdd2", style="filled"]
    ctx_foundation_context_KERNEL_PHILOSOPHY_md [label="Kernel Philosophy\nMechanism vs policy design\n~2782 tok", shape=note, fillcolor="#ffe0b2", style="filled"]
    ctx_foundation_context_LANGUAGE_PHILOSOPHY_md [label="Language Philosophy\nAI-first language choices\n~3723 tok", shape=note, fillcolor="#ffe0b2", style="filled"]

    // Reference directories
    ctx_foundation_examples [label="Examples Directory\nWorking code samples\n~0 tok", shape=note, fillcolor="#c8e6c9", style="filled"]
    ctx_foundation_behaviors [label="Behaviors Directory\nReusable behavior definitions\n~0 tok", shape=note, fillcolor="#c8e6c9", style="filled"]
    ctx_foundation_agents [label="Agents Directory\nAll agent definitions\n~0 tok", shape=note, fillcolor="#c8e6c9", style="filled"]

    // Shared context
    ctx_foundation_context_shared [label="Shared Context\nCommon instructions\n~0 tok", shape=note, fillcolor="#c8e6c9", style="filled"]
    ctx_foundation_context_shared_common_system_base_md [label="System Base Instructions\nCore operating guidelines\n~1529 tok", shape=note, fillcolor="#fff9c4", style="filled"]
    ctx_foundation_context_shared_common_agent_base_md [label="Agent Base Instructions\nShared agent operating rules\n~3543 tok", shape=note, fillcolor="#ffe0b2", style="filled"]

    // Delegation targets for cross-domain questions
    del_amplifier_amplifier_expert [label="Amplifier Expert\nEcosystem-wide questions", shape=box, fillcolor="#c8e6c9", style="filled,rounded,dashed"]
    del_core_core_expert [label="Core Expert\nKernel contracts and protocols", shape=box, fillcolor="#c8e6c9", style="filled,rounded,dashed"]

    agent -> tool_tool_filesystem
    agent -> tool_tool_search
    agent -> ctx_foundation_docs
    agent -> ctx_foundation_docs_BUNDLE_GUIDE_md
    agent -> ctx_foundation_docs_AGENT_AUTHORING_md
    agent -> ctx_foundation_docs_PATTERNS_md
    agent -> ctx_foundation_docs_CONCEPTS_md
    agent -> ctx_foundation_docs_API_REFERENCE_md
    agent -> ctx_foundation_docs_URI_FORMATS_md
    agent -> ctx_foundation_context
    agent -> ctx_foundation_context_IMPLEMENTATION_PHILOSOPHY_md
    agent -> ctx_foundation_context_MODULAR_DESIGN_PHILOSOPHY_md
    agent -> ctx_foundation_context_shared_PROBLEM_SOLVING_PHILOSOPHY_md
    agent -> ctx_foundation_context_ISSUE_HANDLING_md
    agent -> ctx_foundation_context_KERNEL_PHILOSOPHY_md
    agent -> ctx_foundation_context_LANGUAGE_PHILOSOPHY_md
    agent -> ctx_foundation_examples
    agent -> ctx_foundation_behaviors
    agent -> ctx_foundation_agents
    agent -> ctx_foundation_context_shared
    agent -> ctx_foundation_context_shared_common_system_base_md
    agent -> ctx_foundation_context_shared_common_agent_base_md
    agent -> del_amplifier_amplifier_expert [style=dashed]
    agent -> del_core_core_expert [style=dashed]

    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_agent [label="Agent", shape=box, fillcolor="#80cbc4", style="filled,bold"]
        leg_tool [label="Tool", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
        leg_ctx [label="Context File", shape=note, fillcolor="#e1bee7", style="filled,rounded"]
        leg_del [label="Delegation Target", shape=box, fillcolor="#c8e6c9", style="filled,rounded,dashed"]
        leg_agent -> leg_tool -> leg_ctx -> leg_del [style=invis]
    }
}