// Ecosystem Expert — coordinates multi-repo development across core, foundation, modules, and bundles
digraph ecosystem_expert {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Ecosystem Expert Agent\nCoordinates multi-repo Amplifier development — workflows, testing, and dependencies"
    labelloc=t
    labeljust=c
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="369a8f6a2c8f6c8f00be2b4397a72685530180a4537c27f387c3756ebfb42e3f"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    agent [label="Ecosystem Expert\nmodel_role: general\ndescription: ~368 tok", shape=box, fillcolor="#c8e6c9", style="filled,bold", color="#80cbc4"]

    // Tools
    tool_tool_bash [label="Shell Commands\nRun cross-repo operations", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
    tool_tool_filesystem [label="File System Access\nNavigate repo structures", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
    tool_tool_search [label="Code Search\nFind across repositories", shape=box, fillcolor="#bbdefb", style="filled,rounded"]

    // Ecosystem-specific context
    ctx_foundation_context_amplifier_dev_ecosystem_map_md [label="Ecosystem Map\nRepo roles and dependencies\n~1067 tok", shape=note, fillcolor="#fff9c4", style="filled"]
    ctx_foundation_context_amplifier_dev_dev_workflows_md [label="Dev Workflows\nCross-repo change patterns\n~1292 tok", shape=note, fillcolor="#fff9c4", style="filled"]
    ctx_foundation_context_amplifier_dev_testing_patterns_md [label="Testing Patterns\nLocal override to shadow to CI\n~2341 tok", shape=note, fillcolor="#ffe0b2", style="filled"]

    // Philosophy context
    ctx_foundation_context_KERNEL_PHILOSOPHY_md [label="Kernel Philosophy\nMechanism vs policy design\n~2782 tok", shape=note, fillcolor="#ffe0b2", style="filled"]
    ctx_foundation_context_IMPLEMENTATION_PHILOSOPHY_md [label="Implementation Philosophy\nRuthless simplicity principles\n~4382 tok", shape=note, fillcolor="#ffcdd2", style="filled"]
    ctx_foundation_context_MODULAR_DESIGN_PHILOSOPHY_md [label="Modular Design Philosophy\nBricks and studs approach\n~1435 tok", shape=note, fillcolor="#fff9c4", style="filled"]
    ctx_foundation_context_LANGUAGE_PHILOSOPHY_md [label="Language Philosophy\nAI-first language choices\n~3723 tok", shape=note, fillcolor="#ffe0b2", style="filled"]
    ctx_foundation_context_shared_PROBLEM_SOLVING_PHILOSOPHY_md [label="Problem Solving Philosophy\nAnalysis-first approach\n~652 tok", shape=note, fillcolor="#c8e6c9", style="filled"]
    ctx_foundation_context_ISSUE_HANDLING_md [label="Issue Handling Guide\nBug triage and resolution\n~8517 tok", shape=note, fillcolor="#ffcdd2", style="filled"]
    ctx_foundation_context_shared_common_agent_base_md [label="Agent Base Instructions\nShared agent operating rules\n~3543 tok", shape=note, fillcolor="#ffe0b2", style="filled"]

    agent -> tool_tool_bash
    agent -> tool_tool_filesystem
    agent -> tool_tool_search
    agent -> ctx_foundation_context_amplifier_dev_ecosystem_map_md
    agent -> ctx_foundation_context_amplifier_dev_dev_workflows_md
    agent -> ctx_foundation_context_amplifier_dev_testing_patterns_md
    agent -> ctx_foundation_context_KERNEL_PHILOSOPHY_md
    agent -> ctx_foundation_context_IMPLEMENTATION_PHILOSOPHY_md
    agent -> ctx_foundation_context_MODULAR_DESIGN_PHILOSOPHY_md
    agent -> ctx_foundation_context_LANGUAGE_PHILOSOPHY_md
    agent -> ctx_foundation_context_shared_PROBLEM_SOLVING_PHILOSOPHY_md
    agent -> ctx_foundation_context_ISSUE_HANDLING_md
    agent -> ctx_foundation_context_shared_common_agent_base_md

    subgraph cluster_legend {
        label="Legend"
        style="filled,rounded"
        fillcolor="white"
        color="#cccccc"
        fontsize=10
        node [shape=box, fontsize=9, width=1.6]
        leg_agent [label="Agent", shape=box, fillcolor="#80cbc4", style="filled,bold"]
        leg_tool [label="Tool", shape=box, fillcolor="#bbdefb", style="filled,rounded"]
        leg_ctx [label="Context File", shape=note, fillcolor="#e1bee7", style="filled,rounded"]
        leg_agent -> leg_tool -> leg_ctx [style=invis]
    }
}