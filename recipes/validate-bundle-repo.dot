Analysis", shape=box, fillcolor="#c8e6c9", style="filled,rounded", tooltip="foundation:zen-architect"]
    cond_step_repo_conventions [label="quality_classification.requ...", shape=diamond, fillcolor="#fff9c4"]
    step_repo_conventions [label="Repo
