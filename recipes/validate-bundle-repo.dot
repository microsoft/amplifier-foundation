digraph validate_bundle_repo {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Validate Bundle Repo — Validates an entire Amplifier bundle repository including:"
    labelloc=t
    labeljust=c
    compound=true
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="db1b70f05eae4eea302b90ff59f197bdd1dd1a529d99cfc60413d240c47950c9"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    start [label="Start", shape=oval, fillcolor="#e0e0e0"]
    done  [label="Done!", shape=oval, fillcolor="#e0e0e0"]

    step_environment_check [label="Environment
Check", shape=box, fillcolor="#bbdefb", style="filled,rounded", tooltip="python3 << 'EOF' import json import sys import subprocess  results = {     'phase': 'environment_pre"]
