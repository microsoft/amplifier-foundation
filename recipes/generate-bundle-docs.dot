digraph "generate-bundle-docs" {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="generate-bundle-docs v3.0.0\nGenerates bundle.dot + bundle.png for the whole repository via bundle_repo_dot()"
    labelloc=t
    labeljust=c
    nodesep=0.5
    ranksep=0.6
    bgcolor="white"
    source_hash="4ea496a869ef361f"

    node [fontname="Helvetica", fontsize=10, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=8]

    _start [label="START", shape=circle, fillcolor="#80cbc4", width=0.6, fixedsize=true]
    generate_bundle_dot [label="generate-bundle-dot\n(bash)", shape=box, fillcolor="#bbdefb"]
    enhance_bundle_dot [label="enhance-bundle-dot\n(agent: foundation:zen-architect\n[ARCHITECT])\n[conditional]\n(on_error: continue)", shape=box, fillcolor="#c8e6c9"]
    write_bundle_dot [label="write-bundle-dot\n(bash)\n(on_error: continue)", shape=box, fillcolor="#bbdefb"]
    summary [label="summary\n(bash)\n(on_error: continue)", shape=box, fillcolor="#bbdefb"]
    _end [label="END", shape=doublecircle, fillcolor="#ef9a9a", width=0.6, fixedsize=true]

    generate_bundle_dot -> enhance_bundle_dot
    enhance_bundle_dot -> write_bundle_dot
    write_bundle_dot -> summary
    _start -> generate_bundle_dot
    summary -> _end

    subgraph cluster_legend {
        label="Legend"
        style="filled"
        fillcolor="white"
        color="#cccccc"
        fontsize=9
        leg_bash [label="bash step", shape=box, fillcolor="#bbdefb", style="filled,rounded", fontsize=8]
        leg_agent [label="agent step", shape=box, fillcolor="#c8e6c9", style="filled,rounded", fontsize=8]
        leg_recipe [label="sub-recipe", shape=component, fillcolor="#e1bee7", style="filled,rounded", fontsize=8]
        leg_foreach [label="foreach loop", shape=parallelogram, fillcolor="#fff9c4", style="filled,rounded", fontsize=8]
    }
}