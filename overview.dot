    file_behavior_redaction [label="Security Redaction\nHides secrets and PII from logs\n1 hook\n~82 tok", shape=box, fillcolor="#e0f2f1", style="filled,rounded"]
    file_behavior_sessions [label="Session Management\nNaming, logging, and analysis\n1 agent · 1 hook\n~140 tok", shape=box, fillcolor="#e0f2f1", style="filled,rounded"]
    file_behavior_shadow_amplifier [label="Shadow Environments\nSafe testing with smoke-test agent\n1 agent\n~239 tok", shape=box, fillcolor="#e0f2f1", style="filled,rounded"]
