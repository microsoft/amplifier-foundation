// Foundation Bundle Overview
// Shows how the main AI assistant is assembled from behaviors, tools, and external packages.
// Orange node = root bundle. Teal nodes = built-in behaviors. Grey dashed nodes = external dependencies.
// Solid arrows = local includes. Dashed arrows = external includes.
// Token costs reflect each file's own configuration size.
digraph foundation {
    rankdir=TB
    fontname="Helvetica"
    fontsize=12
    label="Foundation Bundle — How the AI Assistant Is Assembled"
    labelloc=t
    labeljust=c
    nodesep=0.6
    ranksep=0.7
    bgcolor="white"
    source_hash="7a05f19c23bf8b7a17ddc92cf06eaf2a75ecb739afa6e1b1cf0d1dedd82a32d5"

    node [fontname="Helvetica", fontsize=11, style="filled,rounded"]
    edge [fontname="Helvetica", fontsize=9]

    // Root bundle — the main entry point that composes everything together
    file_foundation [label="Foundation v2.0\nCore AI Assistant Platform\n4 tools · 11 agents · 1 ctx\n~1140 tok", shape=box, fillcolor="#ffe0b2", style="filled,rounded,bold"]

    // Built-in behaviors — each adds a specific capability
    file_behavior_agents [label="Agent Orchestration\nDelegate tool + multi-agent patterns\n2 tools · 2 ctx\n~368 tok", shape=box, fillcolor="#e0f2f1", style="filled,rounded"]
    file_behavior_amplifier_dev [label="Amplifier Dev Workflows\nEcosystem maps, testing, multi-repo\n1 agent · 3 ctx\n~106 tok", shape=box, fillcolor="#e0f2f1", style="filled,rounded"]
