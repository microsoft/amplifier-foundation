// Option B3 Enhanced: Full Inventory + Real Aggregate Token Costs
// Generated from actual amplifier-foundation repo data.
// Token estimates computed: len(content) // 4 (~4 chars/token)
// Fixed: same-repo git+ includes in amplifier-dev now resolved locally (aggregate corrected)

digraph foundation_option_b3_enhanced {
    // --- Graph settings ---
    rankdir=TB
    fontname="Helvetica"
    fontsize=14
    label=<<B>Foundation Bundle — Option B3 Enhanced (Real Aggregates)</B>>
    labelloc=t
    labeljust=l
    pad="0.5,0.4"
    nodesep=0.35
    ranksep=0.9
    bgcolor=white
    compound=true

    // --- Default styles ---
    node [fontname="Helvetica", fontsize=9, shape=box, style="rounded,filled",
          margin="0.12,0.07", height=0.32, color="#bdbdbd"]
    edge [fontname="Helvetica", fontsize=9, arrowsize=0.7]


    // =========================================================================
    // ROOT NODE — aggregate: instruction body + context files + agent descs
    //   body=231 + ctx=1,529 (common-system-base.md) + agents=3,906 (11 agents)
    // =========================================================================
    root [
        label=<
            <TABLE BORDER="0" CELLSPACING="0" CELLPADDING="2">
                <TR><TD><B>Foundation Bundle v2.0</B></TD></TR>
                <TR><TD><FONT POINT-SIZE="7" COLOR="#546e7a">4 tools · 11 agents · 14 external includes</FONT></TD></TR>
                <TR><TD><FONT POINT-SIZE="7" COLOR="#00695c"><B>~5,666 tok aggregate</B></FONT></TD></TR>
                <TR><TD><FONT POINT-SIZE="6" COLOR="#78909c">body 231 + ctx 1,529 + descs 3,906</FONT></TD></TR>
            </TABLE>
        >
        fillcolor="#80cbc4"
        style="rounded,filled,bold"
        penwidth=2.5
        fontsize=11
    ]


    // =========================================================================
    // CLUSTER: Standalone Bundles (4) — thin YAML wrappers; amplifier-dev now traces same-repo includes
    // =========================================================================
    subgraph cluster_standalones {
        label=<<B>Standalone Bundles (4)</B>>
        labeljust=l
        style="rounded,dashed"
        color="#00897b"
        fontname="Helvetica"
        fontsize=10
        fontcolor="#00897b"
        bgcolor="#f5fbfb"

        s_amplifier_dev [label=<amplifier-dev<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">extends root + dev + shadow</FONT><BR/><FONT POINT-SIZE="7" COLOR="#00695c"><B>~11,005 tok aggregate</B></FONT><BR/><FONT POINT-SIZE="6" COLOR="#78909c">root 5,666 + dev 5,068 + shadow 271</FONT>>, fillcolor="#80cbc4"]
        s_minimal [label=<minimal<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">extends root, minimal</FONT><BR/><FONT POINT-SIZE="6" COLOR="#78909c">~0 tok direct</FONT>>, fillcolor="#80cbc4"]
        s_with_anthropic [label=<with-anthropic<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">extends root + provider</FONT><BR/><FONT POINT-SIZE="6" COLOR="#78909c">~0 tok direct</FONT>>, fillcolor="#80cbc4"]
        s_with_openai [label=<with-openai<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">extends root + provider</FONT><BR/><FONT POINT-SIZE="6" COLOR="#78909c">~0 tok direct</FONT>>, fillcolor="#80cbc4"]
    }


    // =========================================================================
    // CLUSTER: Experiments (3) — no token cost
    // =========================================================================
    subgraph cluster_experiments {
        label=<<B>Experiments (3)</B>>
        labeljust=l
        style="rounded,dashed"
        color="#8e24aa"
        fontname="Helvetica"
        fontsize=10
        fontcolor="#8e24aa"
        bgcolor="#fcf5fe"

        e_delegation_only [label="delegation-only", fillcolor="#e1bee7"]
        e_exp_amplifier [label="exp-amplifier-dev", fillcolor="#e1bee7"]
        e_exp_foundation [label="exp-foundation", fillcolor="#e1bee7"]
    }


    // =========================================================================
    // CLUSTER: Behaviors (12) — with real aggregate token costs
    //   aggregate = instruction body + context files + agent descriptions
    // =========================================================================
    subgraph cluster_behaviors {
        label=<<B>Behaviors (12)</B>>
        labeljust=l
        style="rounded,dashed"
        color="#00897b"
        fontname="Helvetica"
        fontsize=10
        fontcolor="#00897b"
        bgcolor="#f9fffe"

        b_agents [label=<agents<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">2 tools · 2 ctx</FONT><BR/><FONT POINT-SIZE="7" COLOR="#00695c"><B>~5,215 tok</B></FONT>>, fillcolor="#e0f2f1"]
        b_amplifier_dev [label=<amplifier-dev<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">1 agent · 3 ctx</FONT><BR/><FONT POINT-SIZE="7" COLOR="#00695c"><B>~5,068 tok</B></FONT>>, fillcolor="#e0f2f1"]
        b_foundation_expert [label=<foundation-expert<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">1 agent · 1 ctx</FONT><BR/><FONT POINT-SIZE="7" COLOR="#00695c"><B>~1,078 tok</B></FONT>>, fillcolor="#e0f2f1"]
        b_logging [label=<logging<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">1 hook</FONT>>, fillcolor="#e0f2f1"]
        b_progress_monitor [label=<progress-monitor<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">1 hook</FONT>>, fillcolor="#e0f2f1"]
        b_redaction [label=<redaction<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">1 hook</FONT>>, fillcolor="#e0f2f1"]
        b_sessions [label=<sessions<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">1 agent · 1 hook</FONT><BR/><FONT POINT-SIZE="7" COLOR="#00695c"><B>~887 tok</B></FONT>>, fillcolor="#e0f2f1"]
        b_shadow_amplifier [label=<shadow-amplifier<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">1 agent</FONT><BR/><FONT POINT-SIZE="7" COLOR="#00695c"><B>~271 tok</B></FONT>>, fillcolor="#e0f2f1"]
        b_status_context [label=<status-context<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">1 hook</FONT>>, fillcolor="#e0f2f1"]
        b_streaming_ui [label=<streaming-ui<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">1 hook</FONT>>, fillcolor="#e0f2f1"]
        b_tasks [label=<tasks<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">1 tool · 2 ctx</FONT><BR/><FONT POINT-SIZE="7" COLOR="#00695c"><B>~5,215 tok</B></FONT>>, fillcolor="#e0f2f1"]
        b_todo_reminder [label=<todo-reminder<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">1 tool · 2 hooks</FONT>>, fillcolor="#e0f2f1"]
    }


    // =========================================================================
    // CLUSTER: Agents (16) — individual description token costs
    // =========================================================================
    subgraph cluster_agents {
        label=<<B>Agents (16)</B>>
        labeljust=l
        style="rounded,dashed"
        color="#2e7d32"
        fontname="Helvetica"
        fontsize=10
        fontcolor="#2e7d32"
        bgcolor="#f5faf5"

        a_amplifier_smoke [label=<amplifier-smoke-test<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~271 tok desc</FONT>>, fillcolor="#c8e6c9"]
        a_bug_hunter [label=<bug-hunter<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~190 tok desc</FONT>>, fillcolor="#c8e6c9"]
        a_ecosystem_expert [label=<ecosystem-expert<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~368 tok desc</FONT>>, fillcolor="#c8e6c9"]
        a_explorer [label=<explorer<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~289 tok desc</FONT>>, fillcolor="#c8e6c9"]
        a_file_ops [label=<file-ops<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~371 tok desc</FONT>>, fillcolor="#c8e6c9"]
        a_foundation_expert [label=<foundation-expert<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~504 tok desc</FONT>>, fillcolor="#c8e6c9"]
        a_git_ops [label=<git-ops<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~568 tok desc</FONT>>, fillcolor="#c8e6c9"]
        a_integration [label=<integration-specialist<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~296 tok desc</FONT>>, fillcolor="#c8e6c9"]
        a_modular_builder [label=<modular-builder<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~458 tok desc</FONT>>, fillcolor="#c8e6c9"]
        a_post_cleanup [label=<post-task-cleanup<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~367 tok desc</FONT>>, fillcolor="#c8e6c9"]
        a_security [label=<security-guardian<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~459 tok desc</FONT>>, fillcolor="#c8e6c9"]
        a_session_analyst [label=<session-analyst<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~887 tok desc</FONT>>, fillcolor="#c8e6c9"]
        a_shell_exec [label=<shell-exec<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~365 tok desc</FONT>>, fillcolor="#c8e6c9"]
        a_test_coverage [label=<test-coverage<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~190 tok desc</FONT>>, fillcolor="#c8e6c9"]
        a_web_research [label=<web-research<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~376 tok desc</FONT>>, fillcolor="#c8e6c9"]
        a_zen_architect [label=<zen-architect<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~342 tok desc</FONT>>, fillcolor="#c8e6c9"]
    }


    // =========================================================================
    // CLUSTER: Modules (6) — no token cost (runtime code, not per-request)
    // =========================================================================
    subgraph cluster_modules {
        label=<<B>Modules (6)</B>>
        labeljust=l
        style="rounded,dashed"
        color="#e65100"
        fontname="Helvetica"
        fontsize=10
        fontcolor="#e65100"
        bgcolor="#fffaf5"

        m_hooks_deprecation [label="hooks-deprecation", fillcolor="#ffe0b2"]
        m_hooks_proc_guard [label="hooks-process-guard", fillcolor="#ffe0b2"]
        m_hooks_progress [label="hooks-progress-monitor", fillcolor="#ffe0b2"]
        m_hooks_session_name [label="hooks-session-naming", fillcolor="#ffe0b2"]
        m_hooks_todo_display [label="hooks-todo-display", fillcolor="#ffe0b2"]
        m_tool_delegate [label="tool-delegate", fillcolor="#ffe0b2"]
    }


    // =========================================================================
    // CLUSTER: Providers (5) — no token cost (runtime config, not per-request)
    // =========================================================================
    subgraph cluster_providers {
        label=<<B>Providers (5)</B>>
        labeljust=l
        style="rounded,dashed"
        color="#616161"
        fontname="Helvetica"
        fontsize=10
        fontcolor="#616161"
        bgcolor="#fafafa"

        p_anthropic_opus [label="anthropic-opus", fillcolor="#e0e0e0"]
        p_anthropic_sonnet [label="anthropic-sonnet", fillcolor="#e0e0e0"]
        p_openai_gpt [label="openai-gpt", fillcolor="#e0e0e0"]
        p_openai_gpt5 [label="openai-gpt-5", fillcolor="#e0e0e0"]
        p_openai_codex [label="openai-gpt-codex", fillcolor="#e0e0e0"]
    }


    // =========================================================================
    // CLUSTER: Context Files (7) — individual file token costs
    // =========================================================================
    subgraph cluster_context {
        label=<<B>Context Files (7)</B>>
        labeljust=l
        style="rounded,dashed"
        color="#6a1b9a"
        fontname="Helvetica"
        fontsize=10
        fontcolor="#6a1b9a"
        bgcolor="#faf5fc"

        ctx_delegation_instr [label=<delegation-instructions.md<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~3,352 tok</FONT>>, shape=note, fillcolor="#ce93d8"]
        ctx_multiagent_patt [label=<multi-agent-patterns.md<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~1,863 tok</FONT>>, shape=note, fillcolor="#ce93d8"]
        ctx_ecosystem_map [label=<ecosystem-map.md<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~1,067 tok</FONT>>, shape=note, fillcolor="#ce93d8"]
        ctx_dev_workflows [label=<dev-workflows.md<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~1,292 tok</FONT>>, shape=note, fillcolor="#ce93d8"]
        ctx_testing_patterns [label=<testing-patterns.md<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~2,341 tok</FONT>>, shape=note, fillcolor="#ce93d8"]
        ctx_bundle_awareness [label=<bundle-awareness.md<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~574 tok</FONT>>, shape=note, fillcolor="#ce93d8"]
        ctx_common_sys_base [label=<common-system-base.md<BR/><FONT POINT-SIZE="7" COLOR="#546e7a">~1,529 tok</FONT>>, shape=note, fillcolor="#ce93d8"]
    }


    // =========================================================================
    // CROSS-CATEGORY EDGES
    // =========================================================================

    // Root composes behaviors
    root -> b_agents [
        lhead=cluster_behaviors
        label="  composes  "
        color="#00897b" fontcolor="#00897b" penwidth=1.5
    ]

    // Standalones extend root
    s_amplifier_dev -> root [
        ltail=cluster_standalones
        label="  extends  "
        color="#00897b" fontcolor="#00897b" style=dashed
    ]

    // amplifier-dev includes same-repo behaviors (via git+ URLs, now resolved locally)
    s_amplifier_dev -> b_amplifier_dev [
        label="  includes  "
        color="#00695c" fontcolor="#00695c" style=dashed penwidth=0.8 fontsize=7
    ]
    s_amplifier_dev -> b_shadow_amplifier [
        label="  includes  "
        color="#00695c" fontcolor="#00695c" style=dashed penwidth=0.8 fontsize=7
    ]

    // Providers configure standalones
    p_anthropic_opus -> s_with_anthropic [
        ltail=cluster_providers lhead=cluster_standalones
        label="  configures  "
        color="#757575" fontcolor="#757575" style=dashed
    ]

    // Experiments test root
    e_exp_foundation -> root [
        ltail=cluster_experiments
        label="  tests  "
        color="#8e24aa" fontcolor="#8e24aa" style=dotted
    ]


    // =========================================================================
    // DETAILED RELATIONSHIP EDGES (B3 only)
    // =========================================================================

    // Behavior → Agent ownership (individual edges)
    b_sessions -> a_session_analyst [label="owns" color="#2e7d32" fontcolor="#2e7d32" style=dashed penwidth=0.8 fontsize=7]
    b_foundation_expert -> a_foundation_expert [label="owns" color="#2e7d32" fontcolor="#2e7d32" style=dashed penwidth=0.8 fontsize=7]
    b_amplifier_dev -> a_ecosystem_expert [label="owns" color="#2e7d32" fontcolor="#2e7d32" style=dashed penwidth=0.8 fontsize=7]
    b_shadow_amplifier -> a_amplifier_smoke [label="owns" color="#2e7d32" fontcolor="#2e7d32" style=dashed penwidth=0.8 fontsize=7]

    // Behavior → Module usage (individual edges)
    b_agents -> m_tool_delegate [label="uses" color="#e65100" fontcolor="#e65100" style=dotted penwidth=0.8 fontsize=7]
    b_sessions -> m_hooks_session_name [label="uses" color="#e65100" fontcolor="#e65100" style=dotted penwidth=0.8 fontsize=7]
    b_progress_monitor -> m_hooks_progress [label="uses" color="#e65100" fontcolor="#e65100" style=dotted penwidth=0.8 fontsize=7]
    b_todo_reminder -> m_hooks_todo_display [label="uses" color="#e65100" fontcolor="#e65100" style=dotted penwidth=0.8 fontsize=7]


    // =========================================================================
    // CONTEXT LOADING EDGES
    // =========================================================================

    b_agents -> ctx_delegation_instr [color="#6a1b9a" fontcolor="#6a1b9a" style=dotted penwidth=0.8 arrowsize=0.6]
    b_tasks -> ctx_delegation_instr [color="#6a1b9a" fontcolor="#6a1b9a" style=dotted penwidth=0.8 arrowsize=0.6]
    b_agents -> ctx_multiagent_patt [color="#6a1b9a" fontcolor="#6a1b9a" style=dotted penwidth=0.8 arrowsize=0.6]
    b_tasks -> ctx_multiagent_patt [color="#6a1b9a" fontcolor="#6a1b9a" style=dotted penwidth=0.8 arrowsize=0.6]
    b_amplifier_dev -> ctx_ecosystem_map [color="#6a1b9a" fontcolor="#6a1b9a" style=dotted penwidth=0.8 arrowsize=0.6]
    b_amplifier_dev -> ctx_dev_workflows [color="#6a1b9a" fontcolor="#6a1b9a" style=dotted penwidth=0.8 arrowsize=0.6]
    b_amplifier_dev -> ctx_testing_patterns [color="#6a1b9a" fontcolor="#6a1b9a" style=dotted penwidth=0.8 arrowsize=0.6]
    b_foundation_expert -> ctx_bundle_awareness [color="#6a1b9a" fontcolor="#6a1b9a" style=dotted penwidth=0.8 arrowsize=0.6]
    root -> ctx_common_sys_base [color="#6a1b9a" fontcolor="#6a1b9a" style=dotted penwidth=0.8 arrowsize=0.6]


    // =========================================================================
    // DISCLAIMER NOTE — enhanced with aggregate methodology
    // =========================================================================
    disclaimer [
        shape=plaintext
        fontsize=8
        fontcolor="#9e9e9e"
        label=<
            <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"
                   COLOR="#e0e0e0" BGCOLOR="#fafafa" STYLE="rounded">
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="#9e9e9e">Token estimates: ~4 chars/token</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="#9e9e9e">Bundle totals = instruction + context + agent descriptions</FONT></TD></TR>
                <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="#9e9e9e">Excludes: external includes, runtime tool schemas, sub-session costs</FONT></TD></TR>
            </TABLE>
        >
    ]

    // =========================================================================
    // LEGEND
    // =========================================================================
    legend [
        shape=none
        margin=0
        label=<
            <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4"
                   COLOR="#bdbdbd">
                <TR><TD COLSPAN="2" BGCOLOR="white" BORDER="0"><B>Legend</B></TD></TR>
                <TR><TD BGCOLOR="#80cbc4" WIDTH="14"> </TD><TD ALIGN="LEFT" BGCOLOR="white">Bundle</TD></TR>
                <TR><TD BGCOLOR="#e0f2f1" WIDTH="14"> </TD><TD ALIGN="LEFT" BGCOLOR="white">Behavior</TD></TR>
                <TR><TD BGCOLOR="#c8e6c9" WIDTH="14"> </TD><TD ALIGN="LEFT" BGCOLOR="white">Agent</TD></TR>
                <TR><TD BGCOLOR="#ffe0b2" WIDTH="14"> </TD><TD ALIGN="LEFT" BGCOLOR="white">Module</TD></TR>
                <TR><TD BGCOLOR="#e0e0e0" WIDTH="14"> </TD><TD ALIGN="LEFT" BGCOLOR="white">Provider</TD></TR>
                <TR><TD BGCOLOR="#e1bee7" WIDTH="14"> </TD><TD ALIGN="LEFT" BGCOLOR="white">Experiment</TD></TR>
                <TR><TD BGCOLOR="#ce93d8" WIDTH="14"> </TD><TD ALIGN="LEFT" BGCOLOR="white">Context File (note)</TD></TR>
                <TR><TD COLSPAN="2" BGCOLOR="white" BORDER="0"><FONT POINT-SIZE="8">Dashed edge = owns/extends</FONT></TD></TR>
                <TR><TD COLSPAN="2" BGCOLOR="white" BORDER="0"><FONT POINT-SIZE="8">Dotted purple = loads context</FONT></TD></TR>
                <TR><TD COLSPAN="2" BGCOLOR="white" BORDER="0"><FONT POINT-SIZE="8"><B>Bold tok</B> = aggregate (inst + ctx + descs)</FONT></TD></TR>
            </TABLE>
        >
    ]

}
